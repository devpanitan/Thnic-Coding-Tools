<title>แผนการสอนวันที่ 1</title>
<style>
@page { size: A4; margin: 2cm; }
body { font-family: "TH Sarabun PSK","TH SarabunPSK","TH Sarabun New","Sarabun","Tahoma",sans-serif; font-size: 16pt; color:#1a1a1a; line-height:1.45; }
h1 { font-size: 23pt; text-align:center; margin:0 0 2pt; }
h2 { font-size: 18pt; color:#1a4f8a; border-bottom:2px solid #cfe0f5; padding-bottom:3pt; margin:18pt 0 8pt; }
h3 { font-size: 16pt; color:#2f4a7d; margin:12pt 0 4pt; }
.sub { text-align:center; font-size:14pt; color:#555; margin:0 0 14pt; }
table { border-collapse:collapse; width:100%; margin:6pt 0; }
td,th { border:1px solid #9aaecb; padding:7pt 9pt; vertical-align:top; }
th { background:#1a4f8a; color:#fff; font-size:14pt; }
.time { width:18%; white-space:nowrap; font-weight:bold; background:#eef4fb; }
.act { width:34%; font-weight:bold; }
ul { margin:3pt 0; padding-left:20pt; }
li { margin:2pt 0; }
.box { border:1px solid #cfe0f5; background:#f6faff; border-radius:8pt; padding:10pt 14pt; margin:8pt 0; }
.goal { background:#eef9f1; border-color:#bfe6cd; }
.script { background:#fff6dd; border:1px solid #ffe2a1; border-radius:8pt; padding:8pt 14pt; margin:6pt 0; font-size:15pt; }
.script b{ color:#9a6a00; }
.sim { color:#7a5cff; font-weight:bold; }
.code { font-family:"Consolas",ui-monospace,monospace; background:#11203a; color:#e8eefc; padding:12pt 14pt; border-radius:8pt; font-size:14pt; white-space:pre; display:block; }
.tip { font-size:14pt; color:#0c6b46; }
