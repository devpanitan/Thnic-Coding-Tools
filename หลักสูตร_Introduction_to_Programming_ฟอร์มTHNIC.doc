<meta name="ProgId" content="Word.Document">
<title>หลักสูตร Introduction to Programming — ฟอร์ม THNIC</title>
<style>
@page { size: A4; margin: 2cm; }
body { font-family:"TH Sarabun PSK","TH SarabunPSK","Sarabun","Tahoma",sans-serif; font-size:16pt; color:#1a1a1a; line-height:1.4; }
h1 { font-size:20pt; text-align:center; margin:0 0 2pt; }
.sub { text-align:center; font-size:15pt; margin:0 0 4pt; }
.sub2 { text-align:center; font-size:14pt; color:#444; margin:0 0 16pt; }
table.info { border-collapse:collapse; width:100%; margin-bottom:6pt; }
table.info td { border:none; padding:5pt 8pt 5pt 0; vertical-align:top; }
table.info .label { width:30%; font-weight:bold; white-space:nowrap; }
ul { margin:2pt 0; padding-left:20pt; }
li { margin:1.5pt 0; }
h2 { font-size:17pt; color:#1a4f8a; margin:16pt 0 6pt; border-bottom:1.5px solid #cfe0f5; padding-bottom:2pt; }
table.sched { border-collapse:collapse; width:100%; }
table.sched th,table.sched td { border:1px solid #8aa0c0; padding:6pt 8pt; vertical-align:top; }
table.sched th { background:#1a4f8a; color:#fff; font-size:14pt; }
.day { font-weight:bold; white-space:nowrap; width:13%; }
.date { color:#1a4f8a; font-weight:bold; }
.pagebreak { page-break-before: always; }
</style>
